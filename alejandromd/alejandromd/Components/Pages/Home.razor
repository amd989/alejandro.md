@page "/"
@rendermode InteractiveServer

<PageTitle>Alejandro Mora - Software Engineer</PageTitle>

<div class="intro">
    <div class="intro-content">
        <p class="intro-location">@currentTime · New York, USA</p>
        <h1>Hey, I'm Alejandro Mora <span class="wave-emoji">👋</span></h1>
        <p>
            I'm a Software Engineer based in New York City. I <a href="https://l.alejandro.md/github">code</a>, <a href="https://l.alejandro.md/blog">write</a> and make <a href="https://l.alejandro.md/printables">silly</a> stuff.
        </p>
        <p>
            I'm interested in technology related fields, including Software Development,
            IoT and Technology Integration with a particular interest in ubiquitous computing.
        </p>
    </div>
    <div class="intro-image">
        <img src="/img/profile.jpeg" alt="Alejandro Mora Profile Picture">
    </div>
</div>

<section class="section">
    <a href="https://l.alejandro.md/blog" class="section-heading">
        <h2>Writings</h2>
        <span class="view-all">View all →</span>
    </a>

    <div class="blog-list">
        @foreach (var post in posts)
        {
            <a class="blog-item" href="@post.Link">
                <article class="blog-item-row">
                    <time class="blog-item-date">@post.PublishDate.ToString("MMM dd, yyyy")</time>
                    <span class="blog-item-title">@post.Title</span>
                    <span class="blog-item-views">@post.Views.ToString("N0") views</span>
                </article>
            </a>
        }
    </div>
</section>

<section class="section">
    <a href="/projects" class="section-heading">
        <h2>Projects</h2>
        <span class="view-all">View all →</span>
    </a>

    <div class="projects-grid">
        @foreach (var repo in repositories)
        {
            <a href="@repo.Link">
                <div class="project-card">
                    <h3 class="project-title">@repo.Name</h3>
                    <p class="project-description">@repo.Description</p>
                    <div class="project-meta">
                        @if (!string.IsNullOrEmpty(repo.Language))
                        {
                            <span class="project-language @repo.Language.CssSanitize()"></span>
                            <span>@repo.Language</span>
                        }
                        <span class="project-stars"><svg aria-label="stars" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"></path></svg> @repo.StargazersCount</span>
                    </div>
                </div>
            </a>
        }
    </div>
</section>

@code {
    private string currentTime;

    protected override void OnInitialized()
    {
        currentTime = DateTime.Now.ToString("hh:mm:ss tt");
        var timer = new System.Timers.Timer(1000);
        timer.Elapsed += (sender, args) =>
        {
            InvokeAsync(() =>
            {
                currentTime = DateTime.Now.ToString("hh:mm:ss tt");
                StateHasChanged();
            });
        };
        timer.AutoReset = true;
        timer.Start();
    }
}